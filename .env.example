# Copier en .env et remplir les valeurs

# Minta — variables d'environnement

# Token Hugging Face — requis pour la diarisation pyannote
# Créer sur https://huggingface.co/settings/tokens
# Accepter les conditions de pyannote/speaker-diarization-3.1 sur HF
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxx

# Modèle Whisper : tiny | base | small | medium | large-v3
WHISPER_MODEL=large-v3

# Origine autorisée du frontend (CORS)
FRONTEND_ORIGIN=http://localhost:5173

# Niveau de log : DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ── IA multi-fournisseurs ──────────────────────────────────────────────────
# Fournisseur par défaut : anthropic | openai
AI_DEFAULT_PROVIDER=anthropic

# Clés API (optionnelles ici — peuvent être saisies dans l'interface)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Serveurs MCP préconfigurés (JSON inline, optionnel)
# Exemple minimal avec Linear :
# MCP_SERVERS_JSON={"linear":{"type":"stdio","command":"npx","args":["-y","@linear/mcp-server"],"env":{"LINEAR_API_KEY":"lin_xxx"}}}
MCP_SERVERS_JSON=

# Webhook notifié (POST JSON) à la fin de chaque transcription (optionnel)
WEBHOOK_URL=
